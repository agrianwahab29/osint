# ============================================================
# OSINTTool v6.0 — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false
PORT=5000

# Version
APP_VERSION=6.0.0
APP_ENV=production

# Feature Flags
ENABLE_FREE_MODE=true
ENABLE_HIBP_EMAIL_CHECK=false
ENABLE_HIBP_PASSWORD_CHECK=true
ENABLE_BREACH_CATALOG=true
ENABLE_HUNTER=false
ENABLE_SHODAN=false
ENABLE_VIRUSTOTAL=false
ENABLE_INTELX=false
ENABLE_GITHUB_INTEL=true
ENABLE_PUBLIC_EMAIL_DISCOVERY=true
ENABLE_DOMAIN_FORENSIC=true
ENABLE_TELEGRAM_OSINT=true
ENABLE_DARKWEB_INTEL=false
ENABLE_PEOPLE_SEARCH=false
ENABLE_GOOGLE_DORKS=true
ENABLE_PASSWORD_EXPOSURE=true

# API Keys (leave empty for free mode)
HIBP_API_KEY=
HUNTER_API_KEY=
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
INTELX_API_KEY=
INTELX_KEY=
TELEGRAM_BOT_TOKEN=

# Database
DATABASE_PATH=osint.db
